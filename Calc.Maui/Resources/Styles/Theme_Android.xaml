<?xml version="1.0" encoding="utf-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
                    x:Class="Calc.Maui.Resources.Styles.Theme_Android">

	<Color x:Key="CalcBackground">#F5F5F5</Color>
	<Color x:Key="DisplayColor">#212121</Color>
	<Color x:Key="DisplayText">#000000</Color>

	<Style x:Key="CalcButtonStyle" TargetType="Button">
		<Setter Property="CornerRadius" Value="4" />
		<Setter Property="BackgroundColor" Value="#E0E0E0" />
		<Setter Property="TextColor" Value="Black" />
		<Setter Property="FontSize" Value="20" />
		<Setter Property="HeightRequest" Value="70" />
		<Setter Property="Margin" Value="2" />
		<Setter Property="BorderWidth" Value="0" />
	</Style>

</ResourceDictionary>