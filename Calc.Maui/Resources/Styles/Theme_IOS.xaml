<?xml version="1.0" encoding="utf-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
                    x:Class="Calc.Maui.Resources.Styles.Theme_IOS">

	<Color x:Key="CalcBackground">#FFFFFF</Color>
	<Color x:Key="DisplayColor">#F2F2F7</Color>
	<Color x:Key="DisplayText">#000000</Color>

	<Style x:Key="CalcButtonStyle" TargetType="Button">
		<Setter Property="CornerRadius" Value="15" />
		<Setter Property="BackgroundColor" Value="#F2F2F7" />
		<Setter Property="TextColor" Value="#007AFF" />
		<Setter Property="FontSize" Value="22" />
		<Setter Property="FontAttributes" Value="Bold" />
		<Setter Property="HeightRequest" Value="75" />
		<Setter Property="Margin" Value="5" />
	</Style>

</ResourceDictionary>