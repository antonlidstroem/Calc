<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2022/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">
    <Color x:Key="CalcBackground">#000000</Color>
    <Color x:Key="DisplayColor">#FFFFFF</Color>
    <Style x:Key="CalcButtonStyle" TargetType="Button">
        <Setter Property="CornerRadius" Value="24" />
        <Setter Property="BackgroundColor" Value="#1C1C1C" />
        <Setter Property="TextColor" Value="White" />
        <Setter Property="BorderWidth" Value="1" />
        <Setter Property="BorderColor" Value="#333333" />
    </Style>
</ResourceDictionary>
