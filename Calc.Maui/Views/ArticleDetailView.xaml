<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2022/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Calc.App.Views.ArticleDetailView"
             Title="Detaljer">
    <ScrollView Padding="20">
        <VerticalStackLayout Spacing="15">
            <Label Text="{Binding Article.Title}" FontSize="28" FontAttributes="Bold" />
            <Label Text="{Binding Article.Category}" FontSize="14" TextColor="Gray" />
            
            <Image Source="{Binding Article.Image}" 
                   HeightRequest="200" 
                   Aspect="AspectFill"
                   IsVisible="{Binding Article.Image, Converter={StaticResource StringNotEmptyConverter}}" />

            <Label Text="{Binding Article.Content}" FontSize="16" LineHeight="1.5" />

            <BoxView HeightRequest="1" Color="LightGray" Margin="0,10" />

            <Label Text="Reflektion/Bön" FontSize="18" FontAttributes="Italic" />
            <Label Text="{Binding Article.Prayer}" FontSize="16" FontAttributes="Italic" TextColor="#555" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
