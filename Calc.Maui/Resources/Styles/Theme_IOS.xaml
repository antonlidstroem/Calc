<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2022/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">
    <Color x:Key="CalcBackground">#FFFFFF</Color>
    <Color x:Key="DisplayColor">#000000</Color>
    <Style x:Key="CalcButtonStyle" TargetType="Button">
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="BackgroundColor" Value="#F2F2F7" />
        <Setter Property="TextColor" Value="#007AFF" />
    </Style>
</ResourceDictionary>
