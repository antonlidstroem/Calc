<?xml version="1.0" encoding="utf-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
                    x:Class="Calc.Maui.Resources.Styles.Theme_Samsung">

	<Color x:Key="CalcBackground">#000000</Color>
	<Color x:Key="DisplayColor">#000000</Color>
	<Color x:Key="DisplayText">#FFFFFF</Color>

	<Style x:Key="CalcButtonStyle" TargetType="Button">
		<Setter Property="CornerRadius" Value="35" />
		<Setter Property="BackgroundColor" Value="#1C1C1C" />
		<Setter Property="TextColor" Value="White" />
		<Setter Property="FontSize" Value="24" />
		<Setter Property="HeightRequest" Value="70" />
		<Setter Property="WidthRequest" Value="70" />
		<Setter Property="Margin" Value="2" />
		<Setter Property="BorderWidth" Value="1" />
		<Setter Property="BorderColor" Value="#333333" />
	</Style>

</ResourceDictionary>